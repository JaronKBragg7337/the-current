{
  "name": "the-current",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An autonomous deterministic civilization in a Three.js spectator world.",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.13.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:heartbeat": "tsc -b && vite build --base=/worlds/the-current/",
    "build:heartbeat:verify": "tsx scripts/verify-built-base-path.ts /worlds/the-current/",
    "build:github": "tsc -b && vite build --base=/the-current/",
    "build:github:verify": "tsx scripts/verify-built-base-path.ts /the-current/",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:extended:desktop": "playwright test --project=desktop-chromium --grep-invert @smoke",
    "test:all": "npm run lint && npm run typecheck && npm run test && npm run build",
    "sim:150": "tsx scripts/run-simulation.ts --days 150 --seed current-public-001 --out benchmarks/results/simulation-150d.json",
    "sim:long": "tsx scripts/run-simulation.ts --days 1000 --seed current-endurance-001 --out benchmarks/results/simulation-1000d.json",
    "data:ingest": "tsx scripts/ingest-signals.ts",
    "assets:validate": "tsx scripts/validate-assets.ts && tsx scripts/validate-project-assets.ts",
    "assets:world-kit:optimize": "tsx scripts/optimize-confluence-kit.ts",
    "evidence:visual": "tsx scripts/capture-visual-evidence.ts",
    "licenses:generate": "tsx scripts/dependency-licenses.ts --write",
    "licenses:validate": "tsx scripts/dependency-licenses.ts --check"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "idb": "8.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "three-mesh-bvh": "0.9.11",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@gltf-transform/cli": "4.4.1",
    "@gltf-transform/core": "4.4.1",
    "@gltf-transform/extensions": "4.4.1",
    "@gltf-transform/functions": "4.4.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fake-indexeddb": "6.2.5",
    "fast-check": "4.9.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "meshoptimizer": "1.2.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
